# 环境变量配置
APP_ENV=development
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Frontend 代理 (Vite 开发服务器使用)
# 本地开发: http://localhost:8000
# Docker Compose: http://backend:8000
VITE_API_PROXY_TARGET=http://localhost:8000

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=congress_graph
POSTGRES_USER=congress_user
POSTGRES_PASSWORD=congress_password

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# LLM (第一阶段不使用)
ENABLE_LLM=false
LLM_PROVIDER=
LLM_API_KEY=

# ETL (第一阶段不使用)
ENABLE_REAL_ETL=false

# Graph 查询限制
DEFAULT_GRAPH_LIMIT=200
MAX_GRAPH_LIMIT=500
MAX_GRAPH_DEPTH=2

# Mock Seed
MOCK_RANDOM_SEED=42
MOCK_MEMBER_COUNT=50
MOCK_ORG_COUNT=100
MOCK_POLITICAL_ENTITY_COUNT=20
MOCK_EVENT_COUNT=100
MOCK_CLAIM_COUNT=500
MOCK_SOURCE_DOC_COUNT=500
MOCK_RELATION_COUNT=300
